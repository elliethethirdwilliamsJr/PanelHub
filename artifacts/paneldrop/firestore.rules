rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Feedback collection rules
    match /feedback/{feedbackId} {
      // Allow anyone to read feedback
      allow read: if true;
      
      // Allow anyone to create feedback with validation
      allow create: if request.resource.data.keys().hasAll(['username', 'comment', 'createdAt'])
                    && request.resource.data.comment is string
                    && request.resource.data.comment.size() > 0
                    && request.resource.data.comment.size() <= 500
                    && request.resource.data.username is string
                    && request.resource.data.username.size() <= 30;
      
      // Deny updates and deletes
      allow update, delete: if false;
    }
  }
}
