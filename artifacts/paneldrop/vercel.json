{
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/watch/:path*",
      "destination": "/api/proxy"
    },
    {
      "source": "/api/search",
      "destination": "/api/proxy"
    },
    {
      "source": "/api/trending",
      "destination": "/api/proxy"
    },
    {
      "source": "/api/spotlight",
      "destination": "/api/proxy"
    },
    {
      "source": "/api/popular",
      "destination": "/api/proxy"
    },
    {
      "source": "/api/proxy/:path*",
      "destination": "/api/proxy"
    }
  ]
}
