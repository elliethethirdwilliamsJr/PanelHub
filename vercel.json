{
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/paneldrop/dist",
  "installCommand": "pnpm install",
  "functions": {
    "artifacts/paneldrop/api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
