{
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/paneldrop/dist",
  "installCommand": "pnpm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "artifacts/paneldrop/api/**/*.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
