{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 10
    },
    "api/[...slug].js": {
      "includeFiles": "api/**"
    }
  },
  "routes": [
    {
      "src": "/api/watch/(.*)",
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
