{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/paneldrop/dist",
  "installCommand": "pnpm install",
  "functions": {
    "artifacts/paneldrop/api/**/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
